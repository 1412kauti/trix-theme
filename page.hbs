{{!< default}}

{{#post}}
<div class="article-wrap">
    {{#match @page.show_title_and_feature_image}}
    <div class="article-header">
        {{#if feature_image}}
        <div class="hero-img">
            <img src="{{img_url feature_image size="xl"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0">
        </div>
        {{/if}}
        <h1>{{title}}</h1>
        {{#if custom_excerpt}}
        <p class="deck">{{custom_excerpt}}</p>
        {{else}}
        {{#if excerpt}}
        <p class="deck">{{excerpt}}</p>
        {{/if}}
        {{/if}}
    </div>
    {{/match}}

    <div class="article-main">
        <div class="article-body">
            {{content}}
        </div>
    </div>
</div>
{{/post}}