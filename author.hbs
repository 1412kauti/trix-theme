{{!< default}}

<div class="about-wrap">
    {{#author}}
    <div class="about-photo" style="margin-bottom:40px">
        <div class="tape-piece top-center"></div>
        <div class="photo-frame">
            {{#if profile_image}}
            <img src="{{img_url profile_image size="m"}}" alt="{{name}}" loading="lazy" style="width:100%;height:100%;object-fit:cover;border-radius:50%">
            {{else}}
            <span class="initials">{{#if name}}{{name}}{{else}}KT{{/if}}</span>
            {{/if}}
            <span class="sticker">maker</span>
        </div>
        <div class="about-intro">
            <h2>{{name}}</h2>
            <p>{{bio}}</p>
            {{#if location}}
            <span class="tagline-marker">{{location}}</span>
            {{/if}}
        </div>
    </div>
    {{/author}}

    <div class="section-title-wrap" style="margin-left:0">
        <span class="section-title" style="font-size:18px">Build logs by {{name}}</span>
        <span class="marker-underline thick"></span>
    </div>

    <div class="post-grid" style="padding:0">
        {{#foreach posts}}
        {{> post-card}}
        {{/foreach}}
    </div>
</div>
