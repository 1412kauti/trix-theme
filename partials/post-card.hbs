<div class="post-card{{#if featured}} featured{{/if}}">
    <div class="tape-piece top-center"></div>
    <div class="thumb">
        {{#if feature_image}}
        <img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0">
        {{else}}
        <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="var(--fg-dim)" stroke-width="1.5"><circle cx="12" cy="12" r="8"/><path d="M12 8v4l3 3"/></svg>
        {{/if}}
    </div>
    {{#if primary_tag}}
    <span class="cat">{{primary_tag.name}}</span>
    {{/if}}
    <h3>{{title}}</h3>
    <div class="excerpt">{{excerpt words="20"}}</div>
    <div class="meta-row">
        <span>{{date format="MMM D"}} / {{reading_time minute="1"}}</span>
        <a href="{{url}}" class="read-more">Read</a>
    </div>
</div>
