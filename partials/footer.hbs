<footer>
    <div class="footer-grid">
        <div class="col">
            <h5>{{@site.title}}</h5>
            <p>A workshop notebook for things built, broken, and rebuilt. Robotics, software, CAD, AI, and the occasional 3D-printed disaster.</p>
            <div class="social">
                {{#if @site.twitter_url}}<a href="{{@site.twitter_url}}" aria-label="Twitter" target="_blank" rel="noopener">X</a>{{/if}}
                {{#if @site.facebook_url}}<a href="{{@site.facebook_url}}" aria-label="Facebook" target="_blank" rel="noopener">F</a>{{/if}}
                {{#if @site.primary_author.website_url}}<a href="{{@site.primary_author.website_url}}" aria-label="Website" target="_blank" rel="noopener">W</a>{{/if}}
            </div>
        </div>
        <div class="col">
            <h5>Explore</h5>
            <a href="{{@site.url}}">Home</a>
            <a href="{{@site.url}}/archive/">Archive</a>
            <a href="{{@site.url}}/about/">About</a>
            <a href="{{@site.url}}/tags/">Tags</a>
            <a href="{{@site.url}}/authors/">Authors</a>
        </div>
        <div class="col">
            <h5>Categories</h5>
            {{#get "tags" limit="all"}}
                {{#foreach tags}}
                <a href="{{url}}">{{name}}</a>
                {{/foreach}}
            {{/get}}
        </div>
        <div class="col">
            <h5>More</h5>
            <a href="{{@site.url}}/#/portal/">Membership</a>
            <a href="{{@site.url}}/#/portal/">Newsletter</a>
            <a href="{{@site.url}}/privacy/">Privacy Policy</a>
            <a href="{{@site.url}}/contact/">Contact</a>
        </div>
    </div>
    <div class="footer-stamp">Made in a workshop / Smoke & mistakes / Rewired with coffee and duct tape</div>
</footer>
