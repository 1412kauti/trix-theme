<header>
    <a href="{{@site.url}}" class="logo-wrap">
        {{#if @site.logo}}
        <img src="{{@site.logo}}" alt="{{@site.title}}" class="logo-img">
        {{else}}
        <svg width="38" height="38" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="50" r="45" stroke="#000000" stroke-width="1.5" stroke-dasharray="2 4" opacity="0.4"/>
            <circle cx="50" cy="50" r="40" fill="#ff8800" stroke="#000000" stroke-width="2.5"/>
            <line x1="5" y1="50" x2="95" y2="50" stroke="#000000" stroke-width="1" stroke-dasharray="1 3" opacity="0.3"/>
            <line x1="50" y1="5" x2="50" y2="95" stroke="#000000" stroke-width="1" stroke-dasharray="1 3" opacity="0.3"/>
            <path d="M50 75 C 65 75, 63 69, 65 67 C 65 65, 65 59, 65 52" stroke="#000000" stroke-width="4" stroke-linecap="round" fill="none"/>
            <circle cx="26.5" cy="42" r="22" fill="#ffffff" stroke="#000000" stroke-width="3.5"/>
            <circle cx="33.5" cy="42" r="6" fill="#000000"/>
            <circle cx="73.5" cy="42" r="22" fill="#ffffff" stroke="#000000" stroke-width="3.5"/>
            <circle cx="66.5" cy="42" r="6" fill="#000000"/>
            <line x1="48.5" y1="42" x2="51.5" y2="42" stroke="#000000" stroke-width="4"/>
        </svg>
        {{/if}}
        <span class="logo-text">{{@site.title}}</span>
    </a>
    <span class="sep">|</span>
    <div class="nav-links">
        {{#foreach @site.navigation}}
        <a href="{{this.url}}" {{#if current}}class="active"{{/if}}>
            <span class="tape-nav-main"></span>
            <span class="tape-nav-cross"></span>
            <span class="tape-nav-edge"></span>
            {{label}}
        </a>
        {{/foreach}}
        <div class="tag-drop" id="tag-drop" onclick="toggleTagMenu(event)">
            <span>Tags</span>
            <span class="arrow">▾</span>
            <div class="tag-menu">
                {{#get "tags" limit="all"}}
                    {{#foreach tags}}
                    <a href="{{url}}">{{name}}</a>
                    {{/foreach}}
                {{/get}}
            </div>
        </div>
        <button class="search-btn" onclick="openSearch()" aria-label="Search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21"/></svg>
        </button>
    </div>
    <div class="actions">
        <a href="{{@site.url}}/signin/" class="btn-outline">Sign In</a>
        <a href="#" class="btn-amber">Donate</a>
        <a href="{{@site.url}}/#/portal/" class="btn-red">Subscribe</a>
    </div>
</header>
