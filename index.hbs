{{!< default}}

{{> hero}}

<div class="section-title-wrap">
    <span class="section-title">Fresh off the bench</span>
    <span class="marker-underline"></span>
</div>

{{> manga-panel}}

{{> tag-carousel}}

<div class="section-title-wrap">
    <span class="section-title">Featured builds</span>
    <span class="marker-underline thick"></span>
</div>

<div class="post-grid">
    {{#foreach posts}}
    {{> post-card}}
    {{/foreach}}
</div>

<div class="workshop-divider"></div>

<div class="about-strip">
    <div class="tape-piece top-center" style="--tape-angle:-0.5deg"></div>
    <div class="initials-circle">
        KT
        <span class="sticker">hey!</span>
    </div>
    <div class="about-text">
        <h3>Kauti — The Person Behind the Trix</h3>
        <p>Robotics engineer by training, software bender by survival, 3D printing addict by choice. I break things on purpose so I can rebuild them better. This blog is my workshop notebook.</p>
        <span class="annotation">yes, that's me. I'm a bit extra.</span>
    </div>
</div>

{{> newsletter}}
